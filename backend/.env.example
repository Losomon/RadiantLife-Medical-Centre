# MongoDB Connection
# Local: mongodb://localhost:27017/radiantlife
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/radiantlife?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/radiantlife

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (Generate secure key for production)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# CORS Configuration (Update for production)
CORS_ORIGIN=http://localhost:3000

# Session/Token Settings
JWT_EXPIRES_IN=24h
